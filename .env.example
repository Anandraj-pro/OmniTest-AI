# ── Authentication ──────────────────────────────────────
# DEFAULT: use your monthly Claude subscription. Leave ANTHROPIC_API_KEY blank
# and log in once with your subscription account:
#     claude            # (Claude Code login)  — or —   ant auth login
# The SDK's zero-arg client then uses that OAuth profile. No key needed.
#
# FALLBACK: to use pay-per-token API billing instead, set the key below.
ANTHROPIC_API_KEY=

# ── Model routing: each tier -> (provider, model) ───────
# provider = anthropic | ollama.  Default: all Claude.
OMNI_PROVIDER_CHEAP=anthropic
OMNI_PROVIDER_BALANCED=anthropic
OMNI_PROVIDER_SMART=anthropic
OMNI_MODEL_CHEAP=claude-haiku-4-5
OMNI_MODEL_BALANCED=claude-sonnet-5
OMNI_MODEL_SMART=claude-opus-4-8

# ── Local LLM (Ollama) — free, on your machine ──────────
# To run the CHEAP tier locally for $0, uncomment these two lines:
#   OMNI_PROVIDER_CHEAP=ollama
#   OMNI_MODEL_CHEAP=qwen2.5:7b
# Prereqs:  ollama serve   &&   ollama pull qwen2.5:7b
OMNI_OLLAMA_HOST=http://localhost:11434

# ── Prompt tracking (manager visibility) ────────────────
OMNI_PROMPT_LOG_DIR=artifacts/prompts
OMNI_PROMPT_CACHE=true

# ── Alerting ────────────────────────────────────────────
# Slack incoming-webhook URL. When set, the nightly benchmark pings this channel
# if any provider/suite drops below the accuracy threshold. Leave blank to disable.
OMNI_SLACK_WEBHOOK_URL=
# Public URL where the Allure report is published (e.g. CI/static host). When set,
# Slack alerts include a clickable "Open Allure Report" button.
OMNI_REPORT_BASE_URL=

# ── Application under test ──────────────────────────────
OMNI_BASE_URL=https://example.com
OMNI_API_BASE_URL=https://api.example.com

# ── Email: SMTP/IMAP adapter ────────────────────────────
OMNI_EMAIL_BACKEND=smtp_imap          # smtp_imap | gmail_api
OMNI_SMTP_HOST=smtp.gmail.com
OMNI_SMTP_PORT=587
OMNI_IMAP_HOST=imap.gmail.com
OMNI_IMAP_PORT=993
OMNI_EMAIL_USER=you@example.com
OMNI_EMAIL_PASSWORD=app-password-here

# ── Email: Gmail-API adapter (optional) ─────────────────
OMNI_GMAIL_CREDENTIALS=secrets/gmail_credentials.json
OMNI_GMAIL_TOKEN=secrets/gmail_token.json